	file = {Full Text PDF:/Users/takahashishingo/Zotero/storage/46YC6KKC/Garlea et al. - 2022 - VERDI VERsatile DIffractometer with wide-angle polarization analysis for magnetic structure studies.pdf:application/pdf},
}

@article{qian_centaursmall-_2022,
	title = {{CENTAUR}—{The} small- and wide-angle neutron scattering diffractometer/spectrometer for the {Second} {Target} {Station} of the {Spallation} {Neutron} {Source}},
	volume = {93},
	issn = {0034-6748},
	url = {https://doi.org/10.1063/5.0090527},
	doi = {10.1063/5.0090527},
	abstract = {CENTAUR has been selected as one of the eight initial instruments to be built at the Second Target Station (STS) of the Spallation Neutron Source at Oak Ridge National Laboratory. It is a small-angle neutron scattering (SANS) and wide-angle neutron scattering (WANS) instrument with diffraction and spectroscopic capabilities. This instrument will maximally leverage the high brightness of the STS source, the state-of-the-art neutron optics, and a suite of detectors to deliver unprecedented capabilities that enable measurements over a wide range of length scales with excellent resolution, measurements on smaller samples, and time-resolved investigations of evolving structures. Notably, the simultaneous WANS and diffraction capability will be unique among neutron scattering instruments in the United States. This instrument will provide much needed capabilities for soft matter and polymer sciences, geology, biology, quantum condensed matter, and other materials sciences that need in situ and operando experiments for kinetic and/or out-of-equilibrium studies. Beam polarization and a high-resolution chopper will enable detailed structural and dynamical investigations of magnetic and quantum materials. CENTAUR’s excellent resolution makes it ideal for low-angle diffraction studies of highly ordered large-scale structures, such as skyrmions, shear-induced ordering in colloids, and biomembranes. Additionally, the spectroscopic mode of this instrument extends to lower momentum transfers than are currently possible with existing spectrometers, thereby providing a unique capability for inelastic SANS studies.},
	number = {7},
	urldate = {2026-04-21},
	journal = {Rev. Sci. Instrum.},
	author = {Qian, Shuo (钱朔) and Heller, William and Chen, Wei-Ren and Christianson, Andrew and Do, Changwoo and Wang, Yangyang and Lin, Jiao Y. Y. and Huegle, Thomas and Jiang, Chenyang and Boone, Cristina and Hart, Cameron and Graves, Van},
	month = jul,
	year = {2022},
	pages = {075104},
	file = {Full Text PDF:/Users/takahashishingo/Zotero/storage/MNNCAHDC/Qian et al. - 2022 - CENTAUR—The small- and wide-angle neutron scattering diffractometerspectrometer for the Second Targ.pdf:application/pdf},
}

@misc{neves_single-q_2025,
	title = {Single-\$q\$ {Cycloid} and {Double}-\$q\$ {Vortex} {Lattices} in {Layered} {Magnetic} {Semimetal} {EuAg}\$\_4\${Sb}\$\_2\$},
	url = {http://arxiv.org/abs/2512.16990},
	doi = {10.48550/arXiv.2512.16990},
	abstract = {Recently, a host of exotic magnetic textures such as topologically protected skyrmion lattices has been discovered in several bulk metallic lanthanide compounds. In addition to hosting skyrmion phases, a hallmark of this class of materials is the appearance of numerous spin textures characterized by a superposition of multi-\$q\$ magnetic modulations: spin moiré superlattices. The nuanced energy landscape thus motivates detailed studies to understand the underlying interactions. Here, we comprehensively characterize and model the three zero-field magnetic textures present in one such material, EuAg\$\_4\$Sb\$\_2\$. Systematic symmetry breaking experiments using magnetic field and strain determine that the ground state incommensurate magnetic phase (ICM1) is single-\$q\$. In contrast, ICM2 and ICM3 are both double-\$q\$, {\textbackslash}textit\{i.e.\}, spin moiré superlattices. Further, through application of polarized small angle neutron scattering and spherical neutron polarimetry, we demonstrate that ICM1 is a single-\$q\$ cycloid and ICM2 and ICM3 are double-\$q\$ vortex lattices, with Eu moments lying in the \$ab\$-plane in zero field and with a ferromagnetic component at finite field. Despite the quasi-2D nature of EuAg\$\_4\$Sb\$\_2\$, the modulations propagate out of the {\textbackslash}textit\{ab\}-plane, leading to a shift of the spin texture between triangle lattice planes. Further, the ICM3 to ICM2 transition includes an unusual 45\${\textasciicircum}{\textbackslash}circ\$ rotation of the magnetic vortex lattice. Motivated by the coexistence of such drastically different phases in this compound, we conclude by developing a phenomenological model to understand the stability of these states. Our experimental probes and theoretical modeling definitively characterize three different and tunable phases in one material, and provide insight for the design of new topological spin-texture materials.},
	urldate = {2026-04-21},
	publisher = {arXiv},
	author = {Neves, Paul M. and Kurumaji, Takashi and Wakefield, Joshua P. and Hiess, Arno and Steffens, Paul and Qureshi, Navid and Cubitt, Robert and DeBeer-Schmitt, Lisa M. and Palmstrom, Johanna C. and Hayami, Satoru and Bartkowiak, Marek and Zolliker, Markus and White, Jonathan S. and Checkelsky, Joseph G.},
	month = dec,
	year = {2025},
	note = {arXiv:2512.16990 [cond-mat]},
	file = {Preprint PDF:/Users/takahashishingo/Zotero/storage/K9ULH8BV/Neves et al. - 2025 - Single-\$q\$ Cycloid and Double-\$q\$ Vortex Lattices in Layered Magnetic Semimetal EuAg\$_4\$Sb\$_2\$.pdf:application/pdf},
}

@article{gaudet_spin-orbital_2023,
	title = {Spin-orbital order and excitons in magnetoresistive {HoBi}},
	volume = {107},
	url = {https://link.aps.org/doi/10.1103/PhysRevB.107.104423},
	doi = {10.1103/PhysRevB.107.104423},
	abstract = {The magnetism of the rocksalt fcc rare-earth monopnictide HoBi, a candidate topological material with extreme magnetoresistance, is investigated. From the Ho3+ non-Kramers 𝐽=8 spin-orbital multiplet, the cubic crystal electric field yields six nearly degenerate low-energy levels. These constitute an anisotropic magnetic moment with a Jahn-Teller-like coupling to the lattice. In the cubic phase for 𝑇{\textgreater}𝑇𝑁=5.72⁢(1)⁢K, the paramagnetic neutron scattering is centered at 𝐤=(12⁢12⁢12) and was fit to dominant antiferromagnetic interactions between Ho spins separated by \{100\} and ferromagnetic interactions between spins displaced by \{12⁢12⁢0\}. For 𝑇{\textless}𝑇𝑁, a type-II AFM long-range order with 𝐤=(12⁢12⁢12) develops along with a tetragonal lattice distortion. While neutron diffraction from a multidomain sample cannot unambiguously determine the spin orientation within a domain, the bulk magnetization, structural distortion, and our measurements of the magnetic excitations all show the easy axis coincides with the tetragonal axis. The weakly dispersive excitons for 𝑇{\textless}𝑇𝑁 can be accounted for by a spin Hamiltonian that includes the crystal electric field and exchange interactions within the random phase approximation.},
	number = {10},
	urldate = {2026-04-21},
	journal = {Phys. Rev. B},
	publisher = {American Physical Society},
	author = {Gaudet, J. and Yang, H.-Y. and Smith, E. M. and Halloran, T. and Clancy, J. P. and Rodriguez-Rivera, J. A. and Xu, Guangyong and Zhao, Y. and Chen, W. C. and Sala, G. and Aczel, A. A. and Gaulin, B. D. and Tafti, F. and Broholm, C.},
	month = mar,
	year = {2023},
	pages = {104423},
	file = {Full Text PDF:/Users/takahashishingo/Zotero/storage/H8R8ITZ5/Gaudet et al. - 2023 - Spin-orbital order and excitons in magnetoresistive HoBi.pdf:application/pdf},
}

@phdthesis{campbell_studies_2025,
	address = {United States -- Florida},
	type = {Ph.{D}.},
	title = {Studies of {Complex} {Magnetically} {Ordered} {Materials}: {From} {Low} {Dimensional} {Materials} to {Non}-{Centrosymmetric} {Materials}},
	copyright = {Database copyright ProQuest LLC; ProQuest does not claim copyright in the individual underlying works.},
	isbn = {9798273398115},
	shorttitle = {Studies of {Complex} {Magnetically} {Ordered} {Materials}},
	url = {https://www.proquest.com/docview/3297979833/abstract/DA9A0C75F150470APQ/1},
	abstract = {The focus of this PhD dissertation is the study of crystal structure factors that can lead to complex magnetic ordering in 3d-metal systems. These are much cheaper than rare earth containing magnets and much less explored. Materials such as B20 magnets have garnered much attention lately due to their chiral crystal structure and resultant chiral magnetic ordering which has been studied for spintronic, and as skyrmion hosts. The need to expand studies of this type to new structure types has not been met so far. 3d-metal half-Heusler compounds have shown recent promise for magnetic memory and possible spintronic applications as well. This work explores frustrated magnetism and half-Heusler compounds as possible new paradigms to look for exotic magnetically ordered phases.
There is a brief overview of frustrated materials and pseudo 1d chains followed by an introduction to crystal structure frustration and half-Heusler materials given in chapter 1. Chapter 2 describes all synthetic methods and physical measurements performed in this dissertation. Chapter 3 talks about the magnetic and crystal structure properties of MBi4S7 (M = Mn, Fe). In this study we confirmed the AFM ordering of 67 K for FeBi4S7 and 34 K for MnBi4S7. We performed neutron diffraction on both compounds and solved the magnetic structure of FeBi4S7 which was FM chains that couple AFM to one another. Also we found out MnBi4S7 had an incommensurate magnetic ordering however we were not able to solve it. We saw an unexpected dependance of AFM ordering temperature to applied field in the magnetic susceptibility measurements. This was attributed to the FM intrachain coupling we observed in this compound. The bonding and chemical environment of our magnetic atom was used to justify the magnetic ordering we observed for FeBi4S7.
Chapter 4 describes a half-Heusler solid solution of V1-xCrxCoGe that ranges between the Pnma and P63/mmc space groups. We observed a substitution of Cr into the V site until 40\% Cr was added at which we observed a phase separation. On the other side of the solid solution Cr is substituted by V and the compounds are all in the hexagonal structure type. DFT calculations were performed for CrCoGe and VCoGe in both structure types which showed that VCoGe is more metastable, hence why more substitutes into the Ni2In structure type. None of the compounds showed any magnetic ordering as they were all paramagnetic.
In chapter 5 an interesting half-Heusler system is discussed and we report a new compound MnCoGe1/3As2/3. We discovered a new compound in the phase space between MnCoGe and MnCoAs. MnCoGe adopts a TiNiSi (Pnma) and it undergoes a structural phase transition at 420 K to the Ni2In (P63/mmc) structure type. MnCoAs adopts a TiNiSi structure type. We performed a substitution of Ge for As and we observed a new Fe2P (𝑃𝑃62𝑚𝑚) phase emerge. We grew a single crystal and solved it as well as performed neutron diffraction where we were able to determine the magnetic structure at 200 K and 90 K. At 200 K the magnetic structure is a non-colinear AFM ordering of spins with not magnetic modulation. At 90 K a magnetic modulation vector of k = (0.123, 0, 0) emerges. The solved magnetic structure forms half spirals of spins with a spin density wave propagating through the structure. At lower temperatures we see a secondary incommensurate ordering emerge which we were not able to solve while the original incommensurate ordering satellite peaks moving to other values. Calculations were performed to justify the complex magnetic ordering we observed.
Chapter 6 discusses a half-Heusler compound that is between the MnFeGe and MnFeAs compositions. They form a hexagonal P63/mmc and a tetragonal P4/nmm structure type respectively. We grew a crystal of the composition MnFeGe0.27As0-73 which adopted the tetragonal Cu2Sb structure type. The magnetic properties of this crystal showed ferromagnetic ordering with a TC of around 400 K which is strange given the parent MnFeAs is a high temperature AFM compound. This dramatic change in magnetism is unexpected and interesting to observe in these half-Heusler compounds.
Chapter 7 explores a Mn1-xFexNiAs solid solution where MnNiAs is polymorphic and known to form in both the TiNiSi (Pnma) and Fe2P structure types while FeNiAs adopts the Fe2P structure type. Powder samples of the series with mixed Fe/Mn ratios all adopted the Fe2P structure type. Magnetic susceptibility as well as magnetization measurements were taken on all the samples which showed a broad AFM transition for FeNiAs, and all the mixed Fe/Mn samples while showing a sharp AFM transition at TN = 224 K for the orthorhombic (TiNiSi) polymorph of MnNiAs. A magnetic modulation vector of k = (1/3, 1/3, 0) was obtained for Mn0.6Fe0.4NiAs, Mn0.7Fe0.3NiAs, Mn0.8Fe0.2NiAs, and Mn0.9Fe0.1NiAs samples. For the orthorhombic MnNiAs phase a magnetic modulation vector of k = (0, 0, 0.172) was determined and confirmed by SCND measurements. We observed an interesting evolution in the magnetism of this series. Finally, this dissertation concludes with future outlooks and general overviews in chapter.},
	language = {English},
	urldate = {2026-04-21},
	school = {The Florida State University},
	author = {Campbell, Ian de Botton},
	year = {2025},
	file = {PDF:/Users/takahashishingo/Zotero/storage/KJIIN9KI/Campbell - 2025 - Studies of Complex Magnetically Ordered Materials From Low Dimensional Materials to Non-Centrosymme.pdf:application/pdf},
}

